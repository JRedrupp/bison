{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "repositories": ["JRedrupp/bison"],
  "gitAuthor": "Renovate Bot <renovate-bot@renovateapp.com>",
  "extends": [
    "config:recommended"
  ],
  "pixi": {
    "managerFilePatterns": [
      "/(^|/)pyproject\\.toml$/",
      "/(^|/)pixi\\.toml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["pixi"],
      "groupName": "pixi dependencies"
    },
    {
      "matchPackageNames": ["max"],
      "enabled": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "constraints": {
    "pixi": ">=0.41.0"
  }
}
